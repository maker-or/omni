{
  "$schema": "https://react.doctor/schema/config.json",
  "ignore": {
    "files": [
      "**/node_modules/**",
      "out/**",
      "app-template/**",
      "dist/**",
      "release/**",
      "electron/**",
      "contracts/**",
      "marketing/**",
      "scripts/**"
    ],
    "rules": ["react-compiler/react-compiler"]
  },
  "lint": false,
  "supplyChain": {
    "minScore": 30
  }
}
