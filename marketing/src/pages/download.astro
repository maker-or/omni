---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Download Pipper - Developer Agent Launcher">
    <main class="shell">
        <div
            class="w-[min(480px,100%)] py-12 px-10 text-center flex flex-col items-center"
        >
            <h1
                class="text-[40px] font-bold mt-0 mx-0 mb-3 bg-gradient-to-br from-white to-[#a3a3a3] bg-clip-text text-transparent tracking-[-0.02em] leading-[1.2]"
            >
                Download Pipper
            </h1>
            <p
                class="text-base text-white/50 mt-0 mx-0 mb-8 leading-relaxed max-w-[320px]"
            >
                Get the desktop agent launcher for your local development
                environment.
            </p>

            <div class="w-full mb-8">
                <button
                    class="font-inherit py-4 px-6 rounded-[14px] border border-white/8 bg-white/2 text-white/40 cursor-not-allowed flex items-center justify-between w-full box-border text-left"
                    disabled
                >
                    <div class="flex flex-col gap-0.5">
                        <span class="text-base font-semibold text-white/40"
                            >Download for macOS</span
                        >
                        <span class="text-xs text-white/25"
                            >Apple Silicon & Intel</span
                        >
                    </div>
                    <span
                        class="text-[11px] font-semibold py-1 px-2 rounded-md bg-white/4 border border-white/8 text-white/40 uppercase tracking-wider"
                        >Coming Soon</span
                    >
                </button>
            </div>

            <div class="flex flex-wrap justify-center gap-2">
                <span
                    class="text-xs text-white/40 bg-white/3 border border-white/5 py-1 px-2.5 rounded-full"
                    >Windows</span
                >
                <span
                    class="text-xs text-white/40 bg-white/3 border border-white/5 py-1 px-2.5 rounded-full"
                    >Linux</span
                >
            </div>
        </div>
    </main>
</Layout>
