---
import Layout from "../layouts/Layout.astro";

const macLauncherManifestUrl = "/api/launcher/latest.json";
const windowsLauncherManifestUrl = "/api/launcher/latest-windows.json";
---

<Layout
    title="Download — polarish"
    description="Download pipper code for macOS and Windows."
    pageClass="download-page"
>
    <section
        class="w-full max-w-[80rem] mx-auto px-[clamp(1.5rem,5vw,2.5rem)] pt-10 md:pt-14 pb-10 flex flex-col items-center flex-1 min-h-0 overflow-y-auto font-geist"
    >
        <div class="w-full max-w-[720px] flex flex-col gap-10 max-sm:gap-8">
            <header class="flex flex-col items-center text-center gap-2">
                <h1
                    class="font-medium text-[clamp(1.75rem,4vw,2.75rem)] tracking-[-0.035em] leading-[1.15] opacity-0 animate-fade-in"
                >
                    Download pipper code
                </h1>
                <p
                    class="text-[0.9rem] text-page-fg opacity-0 animate-fade-in [animation-delay:100ms] flex flex-wrap items-center justify-center gap-3"
                >
                    <span id="version-label" aria-live="polite"></span>
                    <a
                        id="changelog-link"
                        class="text-page-fg text-[0.8rem] underline underline-offset-[3px] [text-decoration-color:rgba(161,161,170,0.4)] transition-all duration-300 hover:[text-decoration-color:#d1e1ff]"
                        href="#"
                        target="_blank"
                        rel="noopener noreferrer"
                        style="display:none"
                        >View changelog<span aria-hidden="true">
                            &#8599;</span
                        ></a
                    >
                </p>
            </header>

            <aside
                id="mac-launch-note"
                class="w-full p-[0.9rem_1rem] border border-[rgba(161,161,170,0.22)] rounded-2xl bg-[rgba(250,250,250,0.04)] text-page-fg text-[0.86rem] leading-[1.5] opacity-0 animate-fade-in [animation-delay:150ms]"
                aria-label="Unsigned macOS launch build notice"
            >
                <strong class="font-medium">macOS note:</strong> Make sure that you
                have mise installed, then run the following command in the terminal:
                <code
                    class="block mt-[0.6rem] p-[0.75rem_0.9rem] border border-[rgba(12,58,143,0.15)] rounded-[0.85rem] bg-[rgba(12,58,143,0.04)] whitespace-pre-wrap [overflow-wrap:anywhere] font-geist text-[0.84rem] break-words"
                    >xattr -cr "/Applications/Pipper Code (Alpha).app"</code
                >
            </aside>

            <aside
                id="windows-launch-note"
                class="w-full p-[0.9rem_1rem] border border-[rgba(161,161,170,0.22)] rounded-2xl bg-[rgba(250,250,250,0.04)] text-page-fg text-[0.86rem] leading-[1.5] opacity-0 animate-fade-in [animation-delay:150ms]"
                aria-label="Unsigned Windows launch build notice"
                style="display:none"
            >
                <strong class="font-medium">Windows note:</strong> This build is unsigned.
                If SmartScreen warns you, choose
                <strong>More info</strong> and then
                <strong>Run anyway</strong>, or right-click the installer and
                choose <strong>Run as administrator</strong> if installation is blocked.
            </aside>

            <div
                class="w-full flex flex-row gap-10 opacity-0 animate-fade-in [animation-delay:200ms]"
                id="platforms"
            >
                <section class="flex flex-col gap-3">
                    <div
                        class="flex items-center gap-[0.6rem] pb-2 border-b border-[rgba(12,58,143,0.15)]"
                    >
                        <svg
                            class="w-[1.15em] h-[1.15em] text-page-fg shrink-0"
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 814 1000"
                            aria-hidden="true"
                            ><path
                                fill="currentColor"
                                d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76.5 0-103.7 40.8-165.9 40.8s-105.6-57-155.5-127C46.7 790.7 0 663 0 541.8c0-194.4 126.4-297.5 250.8-297.5 66.1 0 121.2 43.4 162.7 43.4 39.5 0 101.1-46 176.3-46 28.5 0 130.9 2.6 198.3 99.2zm-234-181.5c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 45.4 0 102.5-30.4 135.5-71.3z"
                            ></path></svg
                        >
                        <h2
                            class="font-medium text-[1.1rem] tracking-[-0.01em]"
                        >
                            macOS
                        </h2>
                    </div>
                    <div class="grid grid-cols-2 max-sm:grid-cols-1 gap-2">
                        <a
                            id="arm64-download"
                            class="flex flex-col gap-[0.2rem] p-[0.85rem_1rem] rounded-[10px] border border-[rgba(12,58,143,0.15)] bg-[rgba(255,255,255,0.02)] transition-all duration-200 hover:bg-[rgba(255,255,255,0.06)] hover:border-[rgba(255,255,255,0.15)] hover:-translate-y-px active:translate-y-0 data-[disabled=true]:opacity-50 data-[disabled=true]:cursor-not-allowed data-[disabled=true]:[transform:none] data-[disabled=true]:hover:bg-[rgba(255,255,255,0.02)] data-[disabled=true]:hover:border-[rgba(12,58,143,0.15)]"
                            data-asset="arm64.dmg"
                            data-disabled="true"
                            aria-disabled="true"
                        >
                            <span data-arch class="font-semibold text-[0.95rem]"
                                >Checking latest version…</span
                            >
                            <span class="text-[0.8rem] text-page-fg">.dmg</span>
                        </a>
                    </div>
                    <button
                        id="mac-download-retry"
                        class="self-start mt-1 p-[0.45rem_0.85rem] border border-[rgba(12,58,143,0.15)] rounded-lg bg-[rgba(255,255,255,0.02)] text-page-fg text-[0.82rem] cursor-pointer transition-all duration-200 hover:bg-[rgba(255,255,255,0.06)] hover:border-[rgba(255,255,255,0.15)] hover:text-page-fg"
                        type="button"
                        style="display:none">Retry</button
                    >
                </section>

                <section class="flex flex-col gap-3">
                    <div
                        class="flex items-center gap-[0.6rem] pb-2 border-b border-[rgba(12,58,143,0.15)]"
                    >
                        <svg
                            class="w-[1.15em] h-[1.15em] text-page-fg shrink-0"
                            viewBox="0 0 88 88"
                            xmlns="http://www.w3.org/2000/svg"
                            ><path
                                d="m0 12.402 35.687-4.86.016 34.423-35.67.203zm35.67 33.529.028 34.453L.028 75.48.026 45.7zm4.326-39.025L87.314 0v41.527l-47.318.376zm47.329 39.349-.011 41.34-47.318-6.678-.066-34.739z"
                                fill="#D1E1FF"></path></svg
                        >
                        <h2
                            class="font-medium text-[1.1rem] tracking-[-0.01em]"
                        >
                            Windows
                        </h2>
                    </div>
                    <div class="grid grid-cols-2 max-sm:grid-cols-1 gap-2">
                        <a
                            id="win64-download"
                            class="flex flex-col gap-[0.2rem] p-[0.85rem_1rem] rounded-[10px] border border-[rgba(12,58,143,0.15)] bg-[rgba(255,255,255,0.02)] transition-all duration-200 hover:bg-[rgba(255,255,255,0.06)] hover:border-[rgba(255,255,255,0.15)] hover:-translate-y-px active:translate-y-0 data-[disabled=true]:opacity-50 data-[disabled=true]:cursor-not-allowed data-[disabled=true]:[transform:none] data-[disabled=true]:hover:bg-[rgba(255,255,255,0.02)] data-[disabled=true]:hover:border-[rgba(12,58,143,0.15)]"
                            data-asset="win-x64.exe"
                            data-disabled="true"
                            aria-disabled="true"
                        >
                            <span data-arch class="font-semibold text-[0.95rem]"
                                >Checking latest version…</span
                            >
                            <span class="text-[0.8rem] text-page-fg">.exe</span>
                        </a>
                    </div>
                    <button
                        id="windows-download-retry"
                        class="self-start mt-1 p-[0.45rem_0.85rem] border border-[rgba(12,58,143,0.15)] rounded-lg bg-[rgba(255,255,255,0.02)] text-page-fg text-[0.82rem] cursor-pointer transition-all duration-200 hover:bg-[rgba(255,255,255,0.06)] hover:border-[rgba(255,255,255,0.15)] hover:text-page-fg"
                        type="button"
                        style="display:none">Retry</button
                    >
                </section>
            </div>
        </div>
    </section>
</Layout>

<script define:vars={{ macLauncherManifestUrl, windowsLauncherManifestUrl }}>
    const versionLabel = document.querySelector("#version-label");
    const macLaunchNote = document.querySelector("#mac-launch-note");
    const windowsLaunchNote = document.querySelector("#windows-launch-note");
    const semver =
        /^(0|[1-9]\d*)\.(0|[1-9]\d*)\.(0|[1-9]\d*)(?:-[0-9A-Za-z-]+(?:\.[0-9A-Za-z-]+)*)?$/;

    function validManifest(value, extension) {
        if (!value || typeof value !== "object" || Array.isArray(value))
            return false;
        if (
            JSON.stringify(Object.keys(value).sort()) !==
            JSON.stringify(["schema_version", "sha256", "url", "version"])
        )
            return false;
        try {
            const url = new URL(value.url);
            return (
                value.schema_version === 1 &&
                semver.test(value.version) &&
                url.protocol === "https:" &&
                url.pathname.toLowerCase().endsWith(extension) &&
                /^[0-9a-fA-F]{64}$/.test(value.sha256)
            );
        } catch {
            return false;
        }
    }

    function updateVersionLabel(version) {
        if (!versionLabel) return;
        const current = versionLabel.textContent?.trim() ?? "";
        if (!current.startsWith("Version ")) {
            versionLabel.textContent = `Version ${version}`;
            return;
        }
        const existing = current.slice("Version ".length);
        if (existing === version) return;
        versionLabel.textContent = `Versions macOS ${existing} / Windows ${version}`;
    }

    async function resolvePlatformDownload({
        cardId,
        retryId,
        manifestUrl,
        extension,
        readyLabel,
        launchNote,
    }) {
        const card = document.querySelector(cardId);
        const retry = document.querySelector(retryId);
        const arch = card?.querySelector("[data-arch]");
        card?.setAttribute("data-disabled", "true");
        card?.setAttribute("aria-disabled", "true");
        card?.removeAttribute("href");
        if (retry) retry.style.display = "none";
        if (arch) arch.textContent = "Checking latest version…";
        try {
            if (!manifestUrl) throw new Error("Manifest URL is not configured");
            const response = await fetch(manifestUrl, { cache: "no-store" });
            if (!response.ok) throw new Error(`HTTP ${response.status}`);
            const manifest = await response.json();
            if (!validManifest(manifest, extension))
                throw new Error("Invalid manifest");
            card.href = manifest.url;
            card.setAttribute("download", "");
            card.removeAttribute("data-disabled");
            card.removeAttribute("aria-disabled");
            if (arch) arch.textContent = readyLabel;
            updateVersionLabel(manifest.version);
            if (launchNote) launchNote.style.display = "";
        } catch {
            if (arch)
                arch.textContent =
                    "Download temporarily unavailable. Try again.";
            if (retry) retry.style.display = "inline-flex";
        }
    }

    void resolvePlatformDownload({
        cardId: "#arm64-download",
        retryId: "#mac-download-retry",
        manifestUrl: macLauncherManifestUrl,
        extension: ".dmg",
        readyLabel: "Apple Silicon (arm64)",
        launchNote: macLaunchNote,
    });
    void resolvePlatformDownload({
        cardId: "#win64-download",
        retryId: "#windows-download-retry",
        manifestUrl: windowsLauncherManifestUrl,
        extension: ".exe",
        readyLabel: "64-bit (x64)",
        launchNote: windowsLaunchNote,
    });

    document.querySelector("#mac-download-retry")?.addEventListener(
        "click",
        () =>
            void resolvePlatformDownload({
                cardId: "#arm64-download",
                retryId: "#mac-download-retry",
                manifestUrl: macLauncherManifestUrl,
                extension: ".dmg",
                readyLabel: "Apple Silicon (arm64)",
                launchNote: macLaunchNote,
            }),
    );
    document.querySelector("#windows-download-retry")?.addEventListener(
        "click",
        () =>
            void resolvePlatformDownload({
                cardId: "#win64-download",
                retryId: "#windows-download-retry",
                manifestUrl: windowsLauncherManifestUrl,
                extension: ".exe",
                readyLabel: "64-bit (x64)",
                launchNote: windowsLaunchNote,
            }),
    );
</script>
