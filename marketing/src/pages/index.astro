---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <section
        class="w-full max-w-[80rem] mx-auto px-[clamp(1.5rem,5vw,2.5rem)] pt-16 md:pt-28 flex flex-col items-center flex-1 min-h-0 select-none"
    >
        <div class="h-12 md:h-24 flex-shrink-0"></div>
        <div
            class="text-center max-w-5xl mx-auto flex flex-col items-center flex-shrink-0"
        >
            <h1
                class="font-['Averia_Serif_Libre'] text-[#D1E1FF] text-5xl sm:text-6xl md:text-7xl lg:text-[5.5rem] font-normal leading-[0.92] tracking-[-0.05em] animate-fade-in"
            >
                AI Harness<br />that improves itself
            </h1>
        </div>
    </section>
</Layout>
