---
import Layout from "../../layouts/Layout.astro";
import { clerkClient } from "@clerk/astro/server";

const { isAuthenticated, userId, redirectToSignIn } = Astro.locals.auth();

if (!isAuthenticated) {
  return redirectToSignIn();
}

const user = await clerkClient(Astro).users.getUser(userId);
const callbackUrl = Astro.url.searchParams.get("return_to") ?? "";
const payload = user
  ? {
      providerUserId: user.id,
      email: user.emailAddresses?.[0]?.emailAddress ?? null,
      name: user.fullName ?? user.firstName ?? user.username ?? null,
      avatarUrl: user.imageUrl ?? null,
    }
  : null;
---

<Layout title="Completing sign in">
  <main class="shell">
    <section>
      {
        payload ? (
          <p class="text-white/72 m-0">Returning you to the Pipper.</p>
        ) : (
          <p class="text-white/72 m-0">Unable to read the Clerk session.</p>
        )
      }
    </section>
  </main>

  {
    payload && callbackUrl ? (
      <script is:inline define:vars={{ callbackUrl, payload }}>
        const params = new URLSearchParams({
          userId: payload.providerUserId,
          email: payload.email ?? "",
          name: payload.name ?? "",
          avatarUrl: payload.avatarUrl ?? "",
        });
        window.location.replace(`${callbackUrl}?${params.toString()}`);
      </script>
    ) : null
  }
</Layout>
