---
import Layout from "../../layouts/Layout.astro";
import { clerkClient } from "@clerk/astro/server";

const { isAuthenticated, userId, redirectToSignIn } = Astro.locals.auth();

if (!isAuthenticated) {
  return redirectToSignIn();
}

const user = await clerkClient(Astro).users.getUser(userId);
const callbackUrl = Astro.url.searchParams.get("return_to") ?? "";
const payload = user
  ? {
      providerUserId: user.id,
      email: user.emailAddresses?.[0]?.emailAddress ?? null,
      name: user.fullName ?? user.firstName ?? user.username ?? null,
      avatarUrl: user.imageUrl ?? null,
    }
  : null;
---

<Layout title="Completing sign in">
  <main class="shell">
    <section >
      {
        payload ? (
          <p>Returning you to the Pipper.</p>
        ) : (
          <p>Unable to read the Clerk session.</p>
        )
      }
    </section>
  </main>

  {
    payload && callbackUrl ? (
      <script is:inline define:vars={{ callbackUrl, payload }}>
        const params = new URLSearchParams({
          userId: payload.providerUserId,
          email: payload.email ?? "",
          name: payload.name ?? "",
          avatarUrl: payload.avatarUrl ?? "",
        });
        window.location.replace(`${callbackUrl}?${params.toString()}`);
      </script>
    ) : null
  }
</Layout>

<style>
  .shell {
    position: relative;
    z-index: 10;
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 32px;
    box-sizing: border-box;
  }

  .card {
    width: min(560px, 100%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(8, 13, 26, 0.72);
    backdrop-filter: blur(16px);
    border-radius: 24px;
    padding: 32px;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.35);
  }

  h1 {
    margin: 0 0 12px;
  }

  p {
    color: rgba(229, 231, 235, 0.72);
    margin: 0;
  }
</style>
