---
import Layout from "../layouts/Layout.astro";
import { SignInButton, SignUpButton } from "@clerk/astro/components";

const returnTo = Astro.url.searchParams.get("return_to") ?? "";
const callbackUrl = new URL("/auth/complete", Astro.url);
if (returnTo) {
    callbackUrl.searchParams.set("return_to", returnTo);
}
---

<Layout title="Pipper auth">
    <main class="shell">
        <section class="hero">
            <div class="actions">
                <SignInButton
                    mode="redirect"
                    forceRedirectUrl={callbackUrl.toString()}
                    fallbackRedirectUrl={callbackUrl.toString()}
                />

                <SignUpButton
                    mode="redirect"
                    forceRedirectUrl={callbackUrl.toString()}
                    fallbackRedirectUrl={callbackUrl.toString()}
                />
            </div>
        </section>
    </main>
</Layout>

<style>
  .hero {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .actions {
    display: flex;
    gap: 16px;
  }

  /* Style Clerk buttons to look clean and premium */
  .actions :global(button) {
    padding: 12px 24px;
    font-size: 15px;
    font-weight: 600;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.06);
    color: #ffffff;
    cursor: pointer;
    transition: all 200ms ease;
  }

  .actions :global(button:hover) {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.16);
    transform: translateY(-1px);
  }
</style>
