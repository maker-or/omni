---
import Layout from "../layouts/Layout.astro";
import { SignInButton, SignUpButton } from "@clerk/astro/components";

const returnTo = Astro.url.searchParams.get("return_to") ?? "";
const callbackUrl = new URL("/auth/complete", Astro.url);
if (returnTo) {
    callbackUrl.searchParams.set("return_to", returnTo);
}
---

<Layout title="Pipper auth">
    <main class="shell">
        <section class="flex justify-center items-center">
            <div class="flex gap-4 [&_button]:py-3 [&_button]:px-6 [&_button]:text-[15px] [&_button]:font-semibold [&_button]:rounded-xl [&_button]:border [&_button]:border-white/8 [&_button]:bg-white/6 [&_button]:text-white [&_button]:cursor-pointer [&_button]:transition-all [&_button]:duration-200 [&_button]:hover:bg-white/12 [&_button]:hover:border-white/16 [&_button]:hover:-translate-y-0.5">
                <SignInButton
                    mode="redirect"
                    forceRedirectUrl={callbackUrl.toString()}
                    fallbackRedirectUrl={callbackUrl.toString()}
                />

                <SignUpButton
                    mode="redirect"
                    forceRedirectUrl={callbackUrl.toString()}
                    fallbackRedirectUrl={callbackUrl.toString()}
                />
            </div>
        </section>
    </main>
</Layout>
