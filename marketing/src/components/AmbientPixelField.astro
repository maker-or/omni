---
interface Props {
  pixelSize?: number;
  gap?: number;
  intensity?: number;
  fadeStart?: number;
  animated?: boolean;
}

const {
  pixelSize = 6,
  gap = 4,
  intensity = 0.35,
  fadeStart = 0.8,
  animated = true
} = Astro.props;
---

<div class="ambient-pixel-field" data-pixel-size={pixelSize} data-gap={gap} data-intensity={intensity} data-fade-start={fadeStart} data-animated={String(animated)}>
  <!-- Background Glows -->
  <div class="glow-container">
    <div class="glow-field glow-left animate-glow-left"></div>
    <div class="glow-field glow-right animate-glow-right"></div>
  </div>

  <!-- Pixel Grid (Populated on Client-Side) -->
  <div class="pixel-grid"></div>
</div>

<style define:vars={{ pixelSize, gap, fadeStart }}>
  .ambient-pixel-field {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    background: transparent;
    overflow: hidden;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .glow-container {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }

  .glow-field {
    position: absolute;
    border-radius: 9999px;
    filter: blur(100px);
  }

  .glow-left {
    width: 60%;
    height: 60%;
    left: 10%;
    bottom: -20%;
    background: radial-gradient(circle, #545cff 0%, transparent 70%);
    opacity: 0.03;
  }

  .glow-right {
    width: 50%;
    height: 50%;
    right: 15%;
    bottom: -10%;
    background: radial-gradient(circle, #545cff 0%, transparent 70%);
    opacity: 0.02;
    filter: blur(120px);
  }

  /* Keyframe animations for glow fields */
  @keyframes pulse-left {
    0%, 100% {
      opacity: 0.015;
      transform: scale(1) translateY(0);
    }
    50% {
      opacity: 0.04;
      transform: scale(1.05) translateY(-6px);
    }
  }

  @keyframes pulse-right {
    0%, 100% {
      opacity: 0.01;
      transform: scale(1.04) translateY(0);
    }
    50% {
      opacity: 0.03;
      transform: scale(0.96) translateY(8px);
    }
  }

  .animate-glow-left {
    animation: pulse-left 30s ease-in-out infinite;
  }

  .animate-glow-right {
    animation: pulse-right 45s ease-in-out infinite;
  }

  .pixel-grid {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 10;
    display: grid;
    justify-content: center;
    align-content: end;
    /* Mask gradient */
    -webkit-mask-image: linear-gradient(to top, rgba(0, 0, 0, 1) 0%, rgba(0, 0, 0, 0) calc(var(--fadeStart) * 100%), rgba(0, 0, 0, 0) 100%);
    mask-image: linear-gradient(to top, rgba(0, 0, 0, 1) 0%, rgba(0, 0, 0, 0) calc(var(--fadeStart) * 100%), rgba(0, 0, 0, 0) 100%);
  }
</style>

<script>
  function initPixelFields() {
    const fields = document.querySelectorAll('.ambient-pixel-field');
    
    fields.forEach(field => {
      const grid = field.querySelector('.pixel-grid');
      if (!grid) return;

      const pixelSize = parseFloat(field.getAttribute('data-pixel-size') || '6');
      const gap = parseFloat(field.getAttribute('data-gap') || '4');
      const intensity = parseFloat(field.getAttribute('data-intensity') || '0.2');

      const seed = Math.random() * 1000;

      function getPixelOpacity(r, c) {
        const x = r + seed;
        const y = c + seed;
        const h = Math.sin(x * 12.9898 + y * 78.233) * 43758.5453123;
        return (h - Math.floor(h)) * intensity;
      }

      function renderGrid() {
        const width = field.clientWidth;
        const height = field.clientHeight;
        const stride = pixelSize + gap;
        const cols = Math.max(0, Math.floor((width + gap) / stride));
        const rows = Math.max(0, Math.floor((height + gap) / stride));

        grid.style.gridTemplateColumns = `repeat(${cols}, ${pixelSize}px)`;
        grid.style.gridTemplateRows = `repeat(${rows}, ${pixelSize}px)`;
        grid.style.gap = `${gap}px`;

        grid.innerHTML = '';
        
        const fragment = document.createDocumentFragment();
        for (let r = 0; r < rows; r++) {
          for (let c = 0; c < cols; c++) {
            const opacity = getPixelOpacity(r, c);
            const pixel = document.createElement('div');
            pixel.style.width = `${pixelSize}px`;
            pixel.style.height = `${pixelSize}px`;
            pixel.style.borderRadius = '1px';
            pixel.style.opacity = String(opacity);
            // Hardcode a dark theme foreground colour (white with low opacity)
            pixel.style.backgroundColor = 'rgba(255, 255, 255, 0.12)';
            pixel.style.flexShrink = '0';
            pixel.style.transition = 'opacity 300ms';
            fragment.appendChild(pixel);
          }
        }
        grid.appendChild(fragment);
      }

      // Initial render
      renderGrid();

      // Resize observer
      const observer = new ResizeObserver(() => {
        renderGrid();
      });
      observer.observe(field);
    });
  }

  // Run on load and after swaps
  initPixelFields();
  document.addEventListener('astro:page-load', initPixelFields);
</script>
