---
import AmbientPixelField from "../components/AmbientPixelField.astro";
import "../styles/global.css";
const { title = "Pipper Code (Alpha) auth" } = Astro.props;
import Analytics from "@vercel/analytics/astro";
---

<!doctype html>
<html lang="en">
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <Analytics />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
        href="https://fonts.googleapis.com/css2?family=Averia+Serif+Libre:ital,wght@0,300;0,400;0,700;1,300;1,400;1,700&display=swap"
        rel="stylesheet"
    />

    <body>
        <AmbientPixelField intensity={0.4} fadeStart={0.8} />
        <slot />
    </body>
</html>
