---
import Analytics from "@vercel/analytics/astro";
import "../styles/global.css";
const {
    title = "pipper",
    description = "pipper — self-improving agent interface",
    pageClass,
} = Astro.props;
const pagePath = Astro.url.pathname;
const pageName =
    pagePath === "/"
        ? "home"
        : pagePath.replace(/^\/+|\/+$/g, "").replace(/\//g, ".") || "home";
const showDownloadNavLink = pageClass !== "download-page";
---

<html lang="en" class="h-svh overflow-hidden [color-scheme:light]">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <Analytics />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Averia+Serif+Libre:ital,wght@0,300;0,400;0,700;1,300;1,400;1,700&display=swap"
            rel="stylesheet"
        />
        <link
            href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&display=swap"
            rel="stylesheet"
        />
        <link rel="icon" href="/favicon.ico" sizes="48x48" />
        <title>{title}</title>
    </head>
    <body
        class={`${pageClass} antialiased`}
        data-page={pageName}
        style="background:#15408f;color:#d1e1ff"
    >
        <div class="h-svh flex flex-col overflow-hidden">
            <header
                class="w-full max-w-[80rem] mx-auto px-[clamp(1.5rem,5vw,2.5rem)] pt-6 md:pt-10 flex flex-nowrap justify-between items-center flex-shrink-0 gap-6"
            >
                <a
                    href="/"
                    class="font-['Averia_Serif_Libre'] italic text-3xl md:text-4xl tracking-tight text-[#5474AF] hover:text-[#D1E1FF] transition-opacity shrink-0"
                >
                    pipper
                </a>
                <nav
                    class="flex flex-nowrap items-center gap-8 md:gap-12 font-['Averia_Serif_Libre'] text-xl md:text-2xl text-[#5474AF] shrink-0"
                    aria-label="Primary"
                >
                    <a
                        href="https://discord.gg/S928NjYv"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="hover:text-[#D1E1FF] transition-colors whitespace-nowrap"
                        >Discord</a
                    >
                    {
                        showDownloadNavLink ? (
                            <a
                                href="/download"
                                class="hover:text-[#D1E1FF] transition-colors whitespace-nowrap"
                            >
                                Download
                            </a>
                        ) : null
                    }
                </nav>
            </header>
            <main class="main flex-1 flex flex-col items-center w-full min-h-0">
                <slot />
            </main>
        </div>
    </body>
</html>
